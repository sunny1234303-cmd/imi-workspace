{
  "name": "checkmate",
  "version": "1.0.0",
  "description": "Checkmate — 오늘의 모든 것, 항상 여기에",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --mac dmg"
  },
  "dependencies": {
    "@upstash/redis": "^1.38.0",
    "googleapis": "^140.0.0"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.0"
  },
  "build": {
    "appId": "kr.personal.checkmate",
    "productName": "Checkmate",
    "files": [
      "electron/**/*",
      "app/**/*"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "icon": "electron/icon.icns"
    },
    "dmg": {
      "title": "Checkmate 설치",
      "window": {
        "width": 540,
        "height": 380
      }
    }
  }
}
